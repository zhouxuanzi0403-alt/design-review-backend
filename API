// ============================================
// Vercel API 路由 - 设计走查分析
// ============================================
// 这个文件接收来自 Figma 插件的图片，调用 Gemini API 分析差异

import type { VercelRequest, VercelResponse } from '@vercel/node';
import axios from 'axios';

// 从环境变量读取 Gemini API Key
// 在 Vercel 后台设置：GEMINI_API_KEY
const GEMINI_API_KEY = process.env.GEMINI_API_KEY || '';
const GEMINI_MODEL = process.env.GEMINI_MODEL || 'gemini-1.5-pro';
const GEMINI_API_URL = 'https://generativelanguage.googleapis.com/v1beta/models';

// 系统提示词
const SYSTEM_PROMPT = `You are an expert design reviewer specialized in comparing design mockups with live implementations.

Your task is to analyze the provided images and identify visual differences between them.

Analyze the following aspects:
1. Color accuracy (backgrounds, buttons, text, icons)
2. Typography (font size, line height, letter spacing, font weight)
3. Spacing and layout (padding, margins, alignment)
4. Component sizes and dimensions
5. Missing or extra elements
6. Visual hierarchy and consistency

Output Format:
Return a JSON array of differences found. Each difference should include:
- title: Brief description of the issue
- description: Detailed explanation
- severity: "high" | "mid" | "low"
- diffType: Array of difference types (e.g., ["color", "spacing"])
- position: { x: number (0-100), y: number (0-100) } - relative position in percentage

Example output:
[
  {
    "title": "按钮颜色不匹配",
    "description": "主按钮颜色使用了 #007AFF 而不是设计稿中的 #0051D5",
    "severity": "high",
    "diffType": ["color"],
    "position": { "x": 50, "y": 30 }
  },
  {
    "title": "标题字体大小偏大",
    "description": "标题字体大小为 24px 而不是设计稿中的 20px",
    "severity": "mid",
    "diffType": ["typography"],
    "position": { "x": 20, "y": 15 }
  }
]

Important:
- Be precise and specific in your analysis
- Use Chinese for descriptions unless the UI is clearly English
- Estimate positions as percentages (0-100) from top-left
- Prioritize obvious visual differences over minor pixel-perfect issues`;

export default async function handler(req: VercelRequest, res: VercelResponse) {
  // 1. 设置 CORS（允许跨域访问）
  res.setHeader('Access-Control-Allow-Credentials', 'true');
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.setHeader('Access-Control-Allow-Methods', 'GET,OPTIONS,PATCH,DELETE,POST,PUT');
  res.setHeader(
    'Access-Control-Allow-Headers',
    'X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version'
  );

  // 2. 处理 OPTIONS 预检请求
  if (req.method === 'OPTIONS') {
    res.status(200).end();
    return;
  }

  // 3. 只接受 POST 请求
  if (req.method !== 'POST') {
    return res.status(405).json({
      success: false,
      error: 'Method not allowed',
      message: '只支持 POST 请求'
    });
  }

  try {
    // 4. 接收请求数据
    const { designImage, liveImage, instructions = '' } = req.body;

    // 5. 验证数据
    if (!designImage || !liveImage) {
      return res.status(400).json({
        success: false,
        error: '缺少图片数据',
        message: '请提供 designImage 和 liveImage'
      });
    }

    // 6. 检查 API Key
    if (!GEMINI_API_KEY) {
      return res.status(500).json({
        success: false,
        error: 'API Key 未配置',
        message: '请在 Vercel 后台设置 GEMINI_API_KEY 环境变量'
      });
    }

    console.log('📝 收到分析请求');
    console.log('  - 设计稿大小:', designImage.length, '字符');
    console.log('  - 线上稿大小:', liveImage.length, '字符');

    // 7. 调用 Gemini API
    const url = `${GEMINI_API_URL}/${GEMINI_MODEL}:generateContent?key=${GEMINI_API_KEY}`;

    const response = await axios.post(url, {
      contents: [{
        role: 'user',
        parts: [
          { text: SYSTEM_PROMPT },
          { text: instructions || '请分析这两张设计图的差异' },
          {
            inline_data: {
              mime_type: 'image/png',
              data: designImage
            }
          },
          {
            inline_data: {
              mime_type: 'image/png',
              data: liveImage
            }
          },
          { text: '\n\nImage 1 is the design mockup. Image 2 is the live implementation. Please analyze the differences.' }
        ]
      }],
      generationConfig: {
        temperature: 0.7,
        maxOutputTokens: 8192
      }
    }, {
      headers: {
        'Content-Type': 'application/json'
      },
      timeout: 60000 // 60 秒超时
    });

    // 8. 解析 Gemini 响应
    const candidate = response.data?.candidates?.[0];
    if (!candidate) {
      throw new Error('Gemini API 返回了空响应');
    }

    const text = candidate?.content?.parts?.[0]?.text || '';
    if (!text) {
      throw new Error('Gemini API 没有返回文本内容');
    }

    // 9. 提取 JSON 数据
    let diffs = [];
    try {
      // 查找 JSON 数组
      const jsonMatch = text.match(/```json\s*([\s\S]*?)\s*```/) || text.match(/\[[\s\S]*\]/);
      if (jsonMatch) {
        const jsonString = jsonMatch[1] || jsonMatch[0];
        diffs = JSON.parse(jsonString);
      }
    } catch (e) {
      console.error('解析 JSON 失败:', e);
    }

    // 10. 转换为插件格式
    const formattedDiffs = diffs.map((diff, index) => ({
      id: `diff-${Date.now()}-${index}`,
      index,
      severity: diff.severity,
      position: diff.position || { x: 50, y: 50 },
      title: diff.title,
      description: diff.description,
      diffType: diff.diffType || [],
      source: 'ai',
      aiModel: GEMINI_MODEL,
      confidence: 0.8
    }));

    console.log('✅ 分析完成');
    console.log(`  - 找到 ${formattedDiffs.length} 个差异`);

    // 11. 返回结果
    return res.status(200).json({
      success: true,
      data: formattedDiffs,
      timestamp: new Date().toISOString()
    });

  } catch (error: any) {
    console.error('❌ 分析失败:', error);

    // 返回详细错误信息
    let errorMessage = '分析失败';
    let statusCode = 500;

    if (error.response) {
      statusCode = error.response.status;
      const errorData = error.response.data;

      if (statusCode === 401) {
        errorMessage = 'Gemini API Key 无效';
      } else if (statusCode === 404) {
        errorMessage = 'Gemini 模型不存在';
      } else if (statusCode === 429) {
        errorMessage = 'API 调用次数超限，请稍后重试';
      } else if (errorData?.error?.message) {
        errorMessage = errorData.error.message;
      } else {
        errorMessage = `Gemini API 错误 (${statusCode})`;
      }
    } else if (error.code === 'ECONNABORTED') {
      errorMessage = '请求超时，请稍后重试';
    } else if (error.message) {
      errorMessage = error.message;
    }

    return res.status(statusCode).json({
      success: false,
      error: errorMessage,
      message: errorMessage
    });
  }
}
{
  "name": "figma-design-review-backend",
  "version": "1.0.0",
  "description": "Figma 设计走查插件后端",
  "dependencies": {
    "@vercel/node": "^3.0.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "vercel": "^32.0.0"
  }
}
{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "types": ["node"]
  },
  "include": ["api/**/*"],
  "exclude": ["node_modules"]
}
{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    }
  ],
  "env": {
    "GEMINI_API_KEY": "@gemini-api-key",
    "GEMINI_MODEL": "gemini-1.5-pro"
  }
}
